# Census API credential — required for live fetch-aggregate-data and
# list-datasets calls. Get one from https://api.census.gov/data/key_signup.html.
CENSUS_API_KEY=123456

# ──────────────────────────────────────────────────────────────────────
# HTTP server (src/http.ts)
# ──────────────────────────────────────────────────────────────────────

# Port the Streamable HTTP transport binds to.
PORT=3801

# Path to the embedded SQLite metadata file. Rebuild from the fixture with
# `npm run build:sqlite -- --fixture`.
SQLITE_PATH=./census-metadata.sqlite

# Express trust-proxy setting. Unset → false (reject X-Forwarded-For).
# Numeric → hop count to trust. "true" → trust any forwarded header (dev only).
# TRUST_PROXY=1

# When unset the HTTP server is authless (default for public Census data).
# Set to enforce bearer auth on /mcp via crypto.timingSafeEqual.
# MCP_AUTH_TOKEN=replace-me

# ──────────────────────────────────────────────────────────────────────
# Postgres backend (src/services/metadata.service.ts PG adapter,
# still used by the integration tests and legacy stdio entrypoint)
# ──────────────────────────────────────────────────────────────────────

# DATABASE_URL=postgresql://mcp_user_dev:mcp_pass_dev@localhost:5433/mcp_db_dev

# Force a specific backend. Defaults: SQLITE_PATH set → sqlite; DATABASE_URL set → postgres.
# METADATA_BACKEND=sqlite
